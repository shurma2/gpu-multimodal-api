# Copy to .env and adjust. `docker compose` reads .env automatically.

# ---- auth ----------------------------------------------------------------- #
# Public API key (Authorization: Bearer <key>). Leave empty to disable auth.
API_KEY=change-me

# ---- Hugging Face --------------------------------------------------------- #
# Gemma is a gated model: accept the license on its HF page and set a token.
# https://huggingface.co/google/gemma-4-12B-it-qat-q4_0-gguf
HF_TOKEN=

# ---- LLM (Gemma 4 via llama.cpp) ------------------------------------------ #
LLM_HF_REPO=google/gemma-4-12B-it-qat-q4_0-gguf
LLM_HF_QUANT=Q4_0
LLM_MODEL_NAME=gemma-4-12b
LLM_GPU_LAYERS=99          # 99 = offload everything; lower to spill to CPU/RAM
LLM_CONTEXT=8192           # drop to 4096 on 12 GB cards to save VRAM
LLM_PARALLEL=2             # concurrent request slots
# Perf/VRAM. On bleeding-edge llama.cpp use: "--flash-attn on --cache-type-k q8_0 --cache-type-v q8_0"
# LLM_PERF_ARGS=--flash-attn --cache-type-k q8_0 --cache-type-v q8_0
# LLM_EXTRA_ARGS=

# ---- TTS (Qwen3-TTS) ------------------------------------------------------ #
TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_MODEL_NAME=qwen3-tts
TTS_DEFAULT_SPEAKER=Ryan   # fluent-English voices: Ryan, Aiden
TTS_DEFAULT_LANGUAGE=English
TTS_DEVICE=cuda:0
TTS_ATTN=sdpa              # sdpa | flash_attention_2 | eager
# TTS_DEFAULT_INSTRUCT=Speak with a clear, fluent American English accent.
# TTS_STREAM_FRAME_SEC=0.2 # fallback streaming frame size

# ---- gateway -------------------------------------------------------------- #
GATEWAY_TIMEOUT=600
