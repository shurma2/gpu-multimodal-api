# Empty API_KEY disables auth. Set a long random value on remote hosts.
API_KEY=

# llama.cpp / Gemma 3 12B Q4
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLM_MODEL_NAME=gemma-3-12b
LLM_HF_REPO=google/gemma-3-12b-it-qat-q4_0-gguf
LLM_HF_QUANT=Q4_0
LLM_CONTEXT=8192
LLM_PARALLEL=2
LLM_GPU_LAYERS=99

# Python API / audio models
PYTORCH_IMAGE=pytorch/pytorch:2.4.0-cuda12.4-cudnn9-runtime
STT_MODEL_NAME=nemotron-speech-streaming-en-0.6b
STT_MODEL_ID=nvidia/nemotron-speech-streaming-en-0.6b
STT_DEVICE=cuda

TTS_MODEL_NAME=kokoro
TTS_DEVICE=cuda
TTS_DEFAULT_SPEAKER=am_michael
TTS_DEFAULT_LANGUAGE=English

VAD_MODEL_NAME=silero-vad-onnx
VAD_CONFIDENCE=0.7
VAD_START_SECS=0.2
VAD_STOP_SECS=0.2
VAD_MIN_VOLUME=0.6

TURN_MODEL_NAME=smart-turn-v3
TURN_CPU_COUNT=1
TURN_STOP_SECS=3.0
TURN_PRE_SPEECH_MS=500
TURN_MAX_DURATION_SECS=8.0
